# RAG Pipeline Configuration
# Copy this file to .env and update with your settings

# ===== QDRANT CONFIGURATION =====
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=sec-mda-filings
QDRANT_PREFER_GRPC=true

# ===== EMBEDDING CONFIGURATION =====
# Options:
# - sentence-transformers/all-MiniLM-L6-v2 (384 dims, fast)
# - sentence-transformers/all-mpnet-base-v2 (768 dims, better quality)
# - sentence-transformers/all-large-v2 (1024 dims, best quality)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu

# ===== CHUNKING CONFIGURATION =====
# Chunk size in tokens (roughly 4 characters per token)
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Chunking strategy: 'size' or 'section'
CHUNKING_STRATEGY=size

# ===== DATA CONFIGURATION =====
PARQUET_FILE=mda_24_25_merged.parquet
PARQUET_SAMPLE_SIZE=0  # 0 = use all rows

# ===== QUERY CONFIGURATION =====
# Default number of results to return
DEFAULT_TOP_K=5

# Minimum similarity score threshold (0-1)
SEARCH_SCORE_THRESHOLD=0.0

# ===== LOGGING CONFIGURATION =====
LOG_LEVEL=INFO
LOG_FILE=rag_pipeline.log
DEBUG_MODE=false

# ===== PERFORMANCE CONFIGURATION =====
# Number of workers for parallel processing
NUM_WORKERS=1

# Maximum documents to process at once
MAX_BATCH_SIZE=1000

# Cache embeddings in memory
CACHE_EMBEDDINGS=true

# ===== ADVANCED CONFIGURATION =====
# Normalize embeddings
NORMALIZE_EMBEDDINGS=true

# Use TF-IDF weighting for chunks
USE_TF_IDF=false

# Vector store type: 'qdrant' (required)
VECTOR_STORE=qdrant

# ===== DEVELOPMENT =====
# Test mode (uses smaller dataset)
TEST_MODE=false

# Verbose output
VERBOSE=true
